<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFFFFF">

    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#1A56DB"
                android:endColor="#2563EB"
                android:angle="45"/>

            <size
                android:width="40dp"
                android:height="40dp"/>

            <stroke
                android:width="1dp"
                android:color="#3366FF"/>
        </shape>
    </item>

</ripple>