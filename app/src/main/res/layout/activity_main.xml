<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">


    <TextView
        android:id="@+id/tv_auto_connect_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ AUTO"
        android:textSize="8sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="#000102"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:gravity="right"
        android:visibility="gone"/>
    <!-- ===== БЛОК СТАТУСА VPN ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="10dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔴 Отключено"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/color_disconnected"
                android:gravity="center"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tv_connected_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="0dp"/>

        <Button
            android:id="@+id/btn_disconnect"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:textSize="20sp"
            android:text="Отключить"
            android:backgroundTint="@color/color_disconnected"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_traffic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:fontFamily="monospace"
            android:layout_marginTop="6dp"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- ПАНЕЛЬ ИНФОРМАЦИИ (4 строки, всегда видны) -->
    <!-- ════════════════════════════════════════════════════════════════ -->

    <LinearLayout
        android:id="@+id/panel_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:layout_marginTop="8dp"
        android:visibility="visible">

        <!-- Строка 1: Текущий режим ИЛИ прогресс проверки -->
        <TextView
            android:id="@+id/tv_status_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Готов к подключению"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="start"/>

        <!-- Строка 2: Количество серверов (всегда) -->
        <TextView
            android:id="@+id/tv_server_counts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Всего: 0 | ✓ Рабочих: 0 | ✗ Нет связи: 0"
            android:textSize="11sp"
            android:textColor="#8899AA"
            android:gravity="start"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"/>

        <!-- Строка 3: Последнее обновление списка (всегда) -->
        <TextView
            android:id="@+id/tv_last_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Обновлено: не обновлялось"
            android:textSize="11sp"
            android:textColor="#667788"
            android:gravity="start"
            android:layout_marginTop="2dp"/>

        <!-- Строка 4: Последняя проверка серверов (всегда) -->
        <TextView
            android:id="@+id/tv_last_scan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Проверка: не проверялся"
            android:textSize="11sp"
            android:textColor="#667788"
            android:gravity="start"
            android:layout_marginTop="2dp"/>

    </LinearLayout>


    <!-- ===== ПОСЛЕДНИЙ СТАТУС ===== -->
    <TextView
        android:id="@+id/tv_last_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="📊 Всего: 0 | ✓ Рабочих: 0 | Последняя проверка: не проверялся"
        android:textSize="12sp"
        android:textColor="#6688AA"
        android:background="#111827"
        android:visibility="visible"/>

    <!-- ===== ЗАГОЛОВОК ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Топ серверов по скорости"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp"/>

    <!-- ===== СПИСОК ===== -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_servers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>

            <LinearLayout
                android:id="@+id/tv_empty_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="48sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет рабочих серверов"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Потяните вниз для обновления\nили проверьте настройки"
                    android:textSize="14sp"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>