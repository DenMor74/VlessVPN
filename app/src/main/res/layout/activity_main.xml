<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- ===== БЛОК СТАТУСА VPN — фиксированная высота, ничего не прыгает ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:padding="10dp"
        android:elevation="4dp">

        <!-- Строка: статус + кнопка отключить (всегда справа, просто невидима) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔴 Отключено"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/color_disconnected"
                android:gravity="center_vertical"/>

            <!-- Кнопка справа — всегда занимает место, только меняет видимость через invisible -->
            <Button
                android:id="@+id/btn_disconnect"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:text="✕ Откл"
                android:textSize="13sp"
                android:backgroundTint="@color/color_disconnected"
                android:textColor="#FFFFFF"
                android:visibility="invisible"/>

        </LinearLayout>

        <!-- Подключённый сервер — всегда одна строка -->
        <TextView
            android:id="@+id/tv_connected_server"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:gravity="start"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end"/>

        <!-- Трафик — всегда одна строка, просто пустая когда не подключено -->
        <TextView
            android:id="@+id/tv_traffic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=" "
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:gravity="start"
            android:fontFamily="monospace"
            android:layout_marginTop="2dp"
            android:visibility="visible"/>

        <!-- Авто-режим — всегда одна строка, пустая если выкл -->
        <TextView
            android:id="@+id/tv_auto_connect_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=" "
            android:textSize="11sp"
            android:textColor="#AABBCC"
            android:gravity="start"
            android:visibility="visible"/>

    </LinearLayout>

    <!-- ===== ПАНЕЛЬ ИНФОРМАЦИИ (4 строки, всегда видны) ===== -->
    <LinearLayout
        android:id="@+id/panel_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_card"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tv_status_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Готов к подключению"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="start"/>

        <TextView
            android:id="@+id/tv_server_counts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Всего: 0 | ✓ Рабочих: 0 | ✗ Нет связи: 0"
            android:textSize="11sp"
            android:textColor="#8899AA"
            android:gravity="start"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tv_last_update"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Обновлено: не обновлялось"
            android:textSize="11sp"
            android:textColor="#667788"
            android:gravity="start"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_last_scan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Проверка: не проверялся"
            android:textSize="11sp"
            android:textColor="#667788"
            android:gravity="start"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- ===== ПОСЛЕДНИЙ СТАТУС ===== -->
    <TextView
        android:id="@+id/tv_last_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="📊 Всего: 0 | ✓ Рабочих: 0 | Последняя проверка: не проверялся"
        android:textSize="12sp"
        android:textColor="#6688AA"
        android:background="#111827"
        android:visibility="gone"/>

    <!-- ===== ЗАГОЛОВОК СПИСКА ===== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Топ серверов по скорости"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:textAllCaps="true"
        android:letterSpacing="0.08"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"/>

    <!-- ===== СПИСОК СЕРВЕРОВ ===== -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_servers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>

            <LinearLayout
                android:id="@+id/tv_empty_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡"
                    android:textSize="48sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет рабочих серверов"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Потяните вниз для обновления\nили проверьте настройки"
                    android:textSize="14sp"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
