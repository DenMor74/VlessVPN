<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== URL конфигов ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="5dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL с конфигами (с новой строки):"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_config_urls"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="#2C2F3A"
                android:gravity="top|start"
                android:hint="Ссылки на листы подписки (по одной на строку)"
                android:inputType="textMultiLine|textNoSuggestions"
                android:lines="10"
                android:maxLines="16"
                android:minLines="6"
                android:scrollbars="vertical"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- ===== Интервал сканирования ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_scan_interval_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сканировать текущий лист"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>


            <SeekBar
                android:id="@+id/seek_scan_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- ===== Интервал обновления ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_interval_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Скачивать листы: каждые 5 часов"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seek_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="23"/>
        </LinearLayout>

        <!-- ===== Количество серверов ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_top_count_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Выводить на экран серверов: 10"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seek_top_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="29"/>
        </LinearLayout>

        <!-- ===== Сканирование при запуске ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="0dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сканировать серверы при запуске"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <Switch
                android:id="@+id/switch_scan_on_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Если выключено — при запуске показываются последние результаты из базы"
            android:textSize="10sp"
            android:textColor="#888888"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="10dp"/>

        <!-- ===== Тест через LTE ===== -->
        <Switch
            android:id="@+id/switch_force_mobile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Тест через LTE (даже при WiFi)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- ===== Авто-подключение ===== -->
        <Switch
            android:id="@+id/switch_auto_connect_wifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Авто-подключение при потере WiFi"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="При включении: VPN подключится автоматически когда телефон выйдет из зоны WiFi. При возврате в зону WiFi — VPN отключится."
            android:textSize="10sp"
            android:textColor="#888888"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="8dp"/>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- Авто-подключение при потере WiFi -->
        <!-- ════════════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:paddingHorizontal="12dp"
            android:layout_marginVertical="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡 Авто-подключение при проверках"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <Switch
                android:id="@+id/switch_auto_connect_after_scan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Подключать VPN при потере WiFi"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="После проверки серверов: если WiFi отключён → включить VPN, если WiFi появился → выключить VPN"
                android:textSize="12sp"
                android:textColor="#667788"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:background="@color/bg_card"
            android:layout_marginTop="8dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔬 Проверка IP при подключении"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"/>

            <Switch
                android:id="@+id/switch_deep_check"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Запускать проверку IP при подключении "
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- Ночной режим (добавить перед кнопкой "Сохранить") -->
        <!-- ════════════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:background="@color/bg_card"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙 Ночной режим"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <Switch
                android:id="@+id/switch_disable_night_check"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Не проверять ночью (24:00-6:00)"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tv_night_check_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠️ Скачивание и сканирование будет отложено до 6:00 утра"
                android:textSize="12sp"
                android:textColor="#FF9800"
                android:layout_marginTop="4dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ════════════════════════════════════════════════════════════════ -->
        <!-- Чёрный список приложений -->
        <!-- ════════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚫 Приложения в обход VPN"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_blacklist_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Выбрано приложений: 0"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btn_app_blacklist"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Выбрать приложения"
                android:background="@drawable/bg_circle_button"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Трафик этих приложений будет идти напрямую, минуя VPN"
                android:textSize="10sp"
                android:textColor="#999999"
                android:layout_marginBottom="18dp"/>

        </LinearLayout>

        <!-- ===== Глубокая проверка ===== -->


        <!-- ===== AOD Overlay ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:background="@color/bg_card"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📺 Always On Display"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_aod_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Проверка..."
                android:textSize="12sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Для включения: Настройки → Специальные возможности → Загруженные приложения → VlessVPN AOD → Включить"
                android:textSize="11sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- ===== Кнопки ===== -->

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Сохранить"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/bg_circle_button"/>
    </LinearLayout>
</ScrollView>