<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ===== URL конфигов ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="5dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="URL с конфигами (с новой строки):"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/et_config_urls"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:background="#2C2F3A"
                android:gravity="top|start"
                android:hint="Ссылки на листы подписки (по одной на строку)"
                android:inputType="textMultiLine|textNoSuggestions"
                android:lines="10"
                android:maxLines="16"
                android:minLines="6"
                android:scrollbars="vertical"
                android:textColor="#FFFFFF"
                android:textColorHint="#888888"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- ===== Интервал сканирования ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_scan_interval_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сканировать текущий лист"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>


            <SeekBar
                android:id="@+id/seek_scan_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- ===== Интервал обновления ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_interval_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Скачивать листы: каждые 5 часов"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seek_interval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="23"/>
        </LinearLayout>

        <!-- ===== Количество серверов ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tv_top_count_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Выводить на экран серверов: 10"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seek_top_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="29"/>
        </LinearLayout>

        <!-- ===== Сканирование при запуске ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="0dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Сканировать серверы при запуске"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <Switch
                android:id="@+id/switch_scan_on_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Если выключено — при запуске показываются последние результаты из базы"
            android:textSize="10sp"
            android:textColor="#888888"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="10dp"/>

        <!-- ===== Тест через LTE ===== -->
        <Switch
            android:id="@+id/switch_force_mobile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Тест через LTE (даже при WiFi)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- ===== Авто-подключение ===== -->
        <Switch
            android:id="@+id/switch_auto_connect_wifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Авто-подключение при потере WiFi"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="При включении: VPN подключится автоматически когда телефон выйдет из зоны WiFi. При возврате в зону WiFi — VPN отключится."
            android:textSize="10sp"
            android:textColor="#888888"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="24dp"/>

        <!-- ===== Кнопки ===== -->

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Сохранить"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="@drawable/bg_circle_button"/>
    </LinearLayout>
</ScrollView>