<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_rounded"
    android:layout_marginHorizontal="10dp"
    android:layout_marginTop="4dp"
    android:padding="4dp"
    android:elevation="3dp">

    <!-- Верхняя строка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- ✅ Оставили TextView (как в коде), но сделали как иконку -->
        <TextView
            android:id="@+id/tv_server_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:text="●"
            android:textSize="18sp"
            android:gravity="center"
            android:textColor="#888888" />

        <!-- Host + описание -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_server_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="server.example.com"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tv_server_remark"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сервер"
                android:textSize="12sp"
                android:textColor="#8899AA"/>
        </LinearLayout>

        <!-- Пинг -->
        <TextView
            android:id="@+id/tv_server_ping"
            android:layout_width="50dp"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:gravity="end"
            android:fontFamily="monospace"/>

        <!-- ✅ Оставили Button (как в коде), но сделали красивым -->
        <ImageButton
            android:id="@+id/btn_connect"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_connect_button"
            android:src="@drawable/ic_play"
            android:scaleType="fitCenter"
            android:padding="16dp"
            android:visibility="visible"/>

    </LinearLayout>

    <!-- Статус -->
    <TextView
        android:id="@+id/tv_server_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:layout_marginStart="34dp"
        android:text=""
        android:textSize="12sp"
        android:textColor="#667788"
        android:visibility="gone"/>

</LinearLayout>